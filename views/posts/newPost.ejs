<h1>Write your blog here:</h1>

<form action="/posts" method="POST" class="new-post-form">
    <label for="title">Title: </label>
    <input type="text" name="title" id="title" placeholder="title" class="blog-title">
    <br>
    <label for="blog-text">Type blog here: </label>
    <textarea name="content" id="blog-text" class="blog-text" cols="50" rows="30"></textarea>
    <button class="create-post-btn"><a href="" >Post</a></button>
</form>

<a href="/posts">Back to Home</a>

